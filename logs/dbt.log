    create  table
      "dev"."main_marts"."fct_ad_performance_daily__dbt_tmp"
  
    as (
      -- ============================================================================
-- MODEL: fct_ad_performance_daily
-- ============================================================================
-- GRAIN: One row per campaign per day (across all paid channels).
-- PURPOSE: The single, definitive table for all paid media reporting.
--          This is where Metabase connects for spend, CTR, CPC, and CPM.
--
-- METABASE DESIGN:
-- - Pre-calculated metrics (CTR, CPC, CPM) eliminate the need for
--   Metabase custom expressions, reducing query complexity and errors.
-- - Joined with dim_campaigns for dimension attributes so Metabase users
--   can filter by channel, campaign name, or type without writing JOINs.
-- - Joined with dim_date for calendar attributes so "Last 7 days",
--   "This quarter", and "Month over month" all work out of the box.
--
-- EDGE CASES:
-- - Anomalous rows (spend > 0, impressions = 0) are included but flagged.
--   Dashboard creators should add a default filter: is_anomaly = FALSE.
-- - Days with no data (API gaps, weekends with $0 spend) are NOT filled.
--   For continuous time-series charts, Metabase's "Replace missing values
--   with zero" setting handles this at the visualization layer.
-- ============================================================================



WITH performance AS (
    SELECT * FROM "dev"."main"."int_unified_ad_performance"
),

campaigns AS (
    SELECT * FROM "dev"."main_marts"."dim_campaigns"
),

date_dim AS (
    SELECT * FROM "dev"."main_marts"."dim_date"
),

final AS (
    SELECT
        -- ── Keys ────────────────────────────────────────────────
        perf.campaign_key,
        perf.metric_date AS date_day,

        -- ── Campaign dimensions (denormalized for Metabase) ─────
        camp.channel,
        camp.campaign_name,
        camp.campaign_type_standardized,
        camp.campaign_status,
        camp.is_active,

        -- ── Date dimensions (denormalized for Metabase) ─────────
        dd.year_number,
        dd.quarter_number,
        dd.month_number,
        dd.month_name,
        dd.day_name,
        dd.is_weekend,

        -- ── Core metrics ────────────────────────────────────────
        perf.daily_impressions,
        perf.daily_clicks,
        perf.daily_spend_usd,

        -- ── Pre-calculated efficiency metrics ───────────────────
        -- These save Metabase users from writing custom expressions
        -- perf.daily_ctr,
        -- perf.daily_cpc_usd,
        -- 
    CASE
        WHEN CAST(perf.daily_impressions AS DOUBLE) = 0 OR CAST(perf.daily_impressions AS DOUBLE) IS NULL
        THEN NULL
        ELSE CAST(CAST(perf.daily_spend_usd AS DOUBLE) * 1000.0 AS DOUBLE) / NULLIF(CAST(CAST(perf.daily_impressions AS DOUBLE) AS DOUBLE), 0.0)
    END
 AS daily_cpm_usd,

        -- ── Data quality flag ───────────────────────────────────
        perf.is_anomaly

    FROM performance AS perf

    LEFT JOIN campaigns AS camp
        ON perf.campaign_key = camp.campaign_key

    LEFT JOIN date_dim AS dd
        ON perf.metric_date = dd.date_day
)

SELECT * FROM final
    );
  
  
