    create  table
      "dev"."main_marts"."fct_ad_performance_daily__dbt_tmp"
  
    as (
      -- ============================================================================
-- MODEL: fct_ad_performance_daily
-- ============================================================================
-- GRAIN: One row per campaign per day (across all paid channels).
-- PURPOSE: The single, definitive table for all paid media reporting.
--          This is where Metabase connects for spend, CTR, CPC, and CPM.
--
-- METABASE DESIGN:
-- - Pre-calculated metrics (CTR, CPC, CPM) eliminate the need for
--   Metabase custom expressions, reducing query complexity and errors.
-- - Joined with dim_campaigns for dimension attributes so Metabase users
--   can filter by channel, campaign name, or type without writing JOINs.
-- - Joined with dim_date for calendar attributes so "Last 7 days",
--   "This quarter", and "Month over month" all work out of the box.
--
-- EDGE CASES:
-- - Anomalous rows (spend > 0, impressions = 0) are included but flagged.
--   Dashboard creators should add a default filter: is_anomaly = FALSE.
-- - Days with no data (API gaps, weekends with $0 spend) are NOT filled.
--   For continuous time-series charts, Metabase's "Replace missing values
--   with zero" setting handles this at the visualization layer.
-- ============================================================================



WITH  __dbt__cte__int_unified_ad_performance as (
-- ============================================================================
-- MODEL: int_unified_ad_performance
-- ============================================================================
-- GRAIN: One row per channel + campaign + day.
-- PURPOSE: Merge daily ad performance from all three paid channels into a
--          single cross-channel performance table with normalized metrics.
--
-- WHY THIS MATTERS:
-- - This is the single source of truth for "How much did we spend on paid
--   ads yesterday?" — a question that currently requires querying 3 separate
--   platforms and manually summing in a spreadsheet.
-- - By normalizing spend to USD at this layer, all downstream marts and
--   Metabase dashboards can safely SUM/AVG without currency confusion.
--
-- EDGE CASES HANDLED:
-- - Google spend in micros and Meta spend in cents are already converted
--   in staging. LinkedIn reports in decimal dollars natively.
-- - Anomaly detection: rows where spend > 0 but impressions = 0 indicate
--   API glitches or billing artifacts. Flagged as is_anomaly so dashboards
--   can exclude them from efficiency metrics (CTR, CPC) without losing
--   visibility into total spend.
-- - EUR campaigns use a hardcoded conversion rate for demo purposes.
--   In production, this would reference a dim_exchange_rates table.
-- ============================================================================

WITH google_performance AS (
    SELECT
        'google_ads' AS channel,
        source_campaign_id,
        metric_date,
        daily_impressions,
        daily_clicks,
        daily_spend_original_currency AS daily_spend_local,
        currency_code
    FROM "dev"."main_staging"."stg_google_ads__performance_daily"
),

meta_performance AS (
    SELECT
        'meta_ads' AS channel,
        source_campaign_id,
        metric_date,
        daily_impressions,
        daily_clicks,
        daily_spend_original_currency AS daily_spend_local,
        currency_code
    FROM "dev"."main_staging"."stg_meta_ads__performance_daily"
),

linkedin_performance AS (
    SELECT
        'linkedin_ads' AS channel,
        source_campaign_id,
        metric_date,
        daily_impressions,
        daily_clicks,
        daily_spend_usd AS daily_spend_local,
        currency_code
    FROM "dev"."main_staging"."stg_linkedin_ads__performance_daily"
),

-- Stack all channels
unioned AS (
    SELECT * FROM google_performance
    UNION ALL
    SELECT * FROM meta_performance
    UNION ALL
    SELECT * FROM linkedin_performance
),

-- Normalize currency and detect anomalies
final AS (
    SELECT
        -- Cross-channel surrogate key (matches int_unified_campaigns)
        md5(cast(coalesce(cast(channel as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(source_campaign_id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) AS campaign_key,

        channel,
        source_campaign_id,
        metric_date,

        -- Core metrics
        daily_impressions,
        daily_clicks,

        -- Currency normalization
        -- In production: JOIN to dim_exchange_rates ON (currency_code, metric_date)
        -- For demo: EUR → USD at 1.08 fixed rate
        ROUND(
            CASE
                WHEN currency_code = 'EUR' THEN daily_spend_local * 1.08
                ELSE daily_spend_local
            END
        , 6) AS daily_spend_usd,

        daily_spend_local,
        currency_code,

        -- Pre-calculated efficiency metrics (NULL-safe via safe_divide macro)
        
    CASE
        WHEN daily_impressions = 0 OR daily_impressions IS NULL
        THEN NULL
        ELSE CAST(daily_clicks AS DOUBLE) / NULLIF(CAST(daily_impressions AS DOUBLE), 0.0)
    END
 AS daily_ctr,
        
    CASE
        WHEN daily_clicks = 0 OR daily_clicks IS NULL
        THEN NULL
        ELSE CAST(ROUND(CASE WHEN currency_code = 'EUR' THEN daily_spend_local * 1.08 ELSE daily_spend_local END, 6) AS DOUBLE) / NULLIF(CAST(daily_clicks AS DOUBLE), 0.0)
    END
 AS daily_cpc_usd,

        -- Anomaly flag: spend recorded but no impressions served
        -- This catches API sync issues and billing artifacts that would
        -- otherwise distort CTR/CPC calculations in Metabase
        CASE
            WHEN daily_spend_local > 0 AND daily_impressions = 0 THEN TRUE
            ELSE FALSE
        END AS is_anomaly

    FROM unioned
)

SELECT * FROM final
), performance AS (
    SELECT * FROM __dbt__cte__int_unified_ad_performance
),

campaigns AS (
    SELECT * FROM "dev"."main_marts"."dim_campaigns"
),

date_dim AS (
    SELECT * FROM "dev"."main_marts"."dim_date"
),

final AS (
    SELECT
        -- ── Keys ────────────────────────────────────────────────
        perf.campaign_key,
        perf.metric_date AS date_day,

        -- ── Campaign dimensions (denormalized for Metabase) ─────
        camp.channel,
        camp.campaign_name,
        camp.campaign_type_standardized,
        camp.campaign_status,
        camp.is_active,

        -- ── Date dimensions (denormalized for Metabase) ─────────
        dd.year_number,
        dd.quarter_number,
        dd.month_number,
        dd.month_name,
        dd.day_name,
        dd.is_weekend,

        -- ── Core metrics ────────────────────────────────────────
        perf.daily_impressions,
        perf.daily_clicks,
        perf.daily_spend_usd,

        -- ── Pre-calculated efficiency metrics ───────────────────
        -- These save Metabase users from writing custom expressions
        perf.daily_ctr,
        perf.daily_cpc_usd,
        
    CASE
        WHEN perf.daily_impressions = 0 OR perf.daily_impressions IS NULL
        THEN NULL
        ELSE CAST(perf.daily_spend_usd * 1000 AS DOUBLE) / NULLIF(CAST(perf.daily_impressions AS DOUBLE), 0.0)
    END
 AS daily_cpm_usd,

        -- ── Data quality flag ───────────────────────────────────
        perf.is_anomaly

    FROM performance AS perf

    LEFT JOIN campaigns AS camp
        ON perf.campaign_key = camp.campaign_key

    LEFT JOIN date_dim AS dd
        ON perf.metric_date = dd.date_day
)

SELECT * FROM final
    );
  
  
