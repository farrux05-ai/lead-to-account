  create view "dev"."main_staging"."stg_linkedin_ads__performance_daily__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_linkedin_ads__performance_daily
-- ============================================================================
-- GRAIN: One row per campaign, per day.
-- PURPOSE: Extract daily performance metrics. LinkedIn typically outputs 
--          spend already formatted as decimal dollars, so no micro/cent 
--          conversion macro is needed here.
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_linkedin_ads"."linkedin_ads_performance_daily"
),

renamed_and_typed AS (
    SELECT
        -- Dimensional keys
        CAST(campaign_id AS VARCHAR) AS source_campaign_id,
        CAST(date AS DATE) AS metric_date,

        -- Metrics
        COALESCE(CAST(impressions AS INTEGER), 0) AS daily_impressions,
        COALESCE(CAST(clicks AS INTEGER), 0) AS daily_clicks,

        -- Financials: directly using locally reported cost decimal
        CAST(cost_in_usd AS DOUBLE) AS daily_spend_usd,
        CAST(local_currency AS VARCHAR) AS currency_code,

        -- System
        CAST(_loaded_at AS TIMESTAMP) AS _loaded_at

    FROM source
),

deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY source_campaign_id, metric_date 
        ORDER BY _loaded_at DESC
    ) = 1
)

SELECT * FROM deduplicated
  );

