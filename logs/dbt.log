  create view "dev"."main_staging"."stg_meta_ads__campaigns__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_meta_ads__campaigns
-- ============================================================================
-- GRAIN: One row per unique Meta (Facebook/IG) campaign.
-- PURPOSE: Extract Meta campaign metadata and standardise terminology.
--
-- NOTES:
-- - Meta's naming conventions differ from Google's ('objective' vs 'type').
--   We bring in raw values here; cross-platform standardization happens at 
--   the intermediate/marts layer.
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_meta_ads"."meta_ads_campaigns"
),

renamed_and_typed AS (
    SELECT
        -- Primary Key
        CAST(campaign_id AS VARCHAR) AS source_campaign_id,

        -- Attributes
        CAST(campaign_name AS VARCHAR) AS campaign_name,
        CAST(objective AS VARCHAR) AS campaign_objective,
        CAST(status AS VARCHAR) AS campaign_status,
        CAST(currency AS VARCHAR) AS currency_code,

        -- System
        CAST(_loaded_at AS TIMESTAMP) AS _loaded_at

    FROM source
),

deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY source_campaign_id 
        ORDER BY _loaded_at DESC
    ) = 1
)

