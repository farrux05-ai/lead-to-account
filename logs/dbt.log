  create view "dev"."main_staging"."stg_segment__tracks__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_segment__tracks
-- ============================================================================
-- GRAIN: One row per unique user event loop iteration (message_id).
-- PURPOSE: Ingest key mid/bottom-funnel app events mapping to CRM records.
--
-- NOTES:
-- - Segment events come in rapid bursts; deduplication on message_id is
--   a strict requirement for reliable conversion tracking.
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_segment"."segment_tracks"
),

renamed_and_typed AS (
    SELECT
        -- Primary Key
        CAST(message_id AS VARCHAR) AS message_id,

        -- Identifiers (Joined downstream with HubSpot via email/ID)
        CAST(user_id AS VARCHAR) AS user_id,

        -- Event Details
        CAST(event AS VARCHAR) AS event_name,
        CAST(timestamp AS TIMESTAMP) AS event_timestamp,
        
        -- We cast to DATE purely to assist with data partition/spine joins later
        CAST(timestamp AS DATE) AS event_date,

        -- System
        CAST(_loaded_at AS TIMESTAMP) AS _loaded_at

    FROM source
),

deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY message_id 
        ORDER BY _loaded_at DESC
    ) = 1
)

SELECT * FROM deduplicated
  );

[0m15:21:59.728664 [debug] [Thread-3 (]: On model.marketing_warehouse.stg_meta_ads__performance_daily: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "marketing_db", "target_name": "dev", "node_id": "model.marketing_warehouse.stg_meta_ads__performance_daily"} */

  
  create view "dev"."main_staging"."stg_meta_ads__performance_daily__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_meta_ads__performance_daily
-- ============================================================================
-- GRAIN: One row per campaign, per day.
-- PURPOSE: Extract and cast Meta's daily ad performance metrics.
--
-- NOTES:
-- - Meta returns spend in cents, not micros or dollars. We utilize the 
--   cents_to_dollars macro to ensure uniformity before the intermediate layer.
-- - 'date_start' is Meta's convention for the reporting day, mapped to standard
--   'metric_date' alias.
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_meta_ads"."meta_ads_performance_daily"
),

renamed_and_typed AS (
    SELECT
        -- Dimensional keys
        CAST(campaign_id AS VARCHAR) AS source_campaign_id,
        CAST(date_start AS DATE) AS metric_date,

        -- Metrics
        COALESCE(CAST(impressions AS INTEGER), 0) AS daily_impressions,
        COALESCE(CAST(clicks AS INTEGER), 0) AS daily_clicks,

        -- Financials
        
    ROUND(CAST(spend_cents AS DOUBLE) / 100.0, 6)
 AS daily_spend_original_currency,
        CAST(currency AS VARCHAR) AS currency_code,

        -- System
        CAST(_loaded_at AS TIMESTAMP) AS _loaded_at

    FROM source
),

deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY source_campaign_id, metric_date 
        ORDER BY _loaded_at DESC
    ) = 1
)

SELECT * FROM deduplicated
  );

