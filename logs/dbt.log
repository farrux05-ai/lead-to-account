    campaign_key,

    -- Channel identification
    channel,
    source_campaign_id,

    -- Campaign attributes
    campaign_name,
    campaign_type_raw,
    campaign_type_standardized,
    campaign_status,
    currency_code,

    -- Activity flag for default Metabase filters
    is_active

FROM "dev"."main"."int_unified_campaigns"
    );
  
  
