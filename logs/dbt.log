    create  table
      "dev"."main"."int_unified_ad_performance__dbt_tmp"
  
    as (
      -- ============================================================================
-- MODEL: int_unified_ad_performance
-- ============================================================================
-- GRAIN: One row per channel + campaign + day.
-- PURPOSE: Merge daily ad performance from all three paid channels into a
--          single cross-channel performance table with normalized metrics.
--
-- WHY THIS MATTERS:
-- - This is the single source of truth for "How much did we spend on paid
--   ads yesterday?" — a question that currently requires querying 3 separate
--   platforms and manually summing in a spreadsheet.
-- - By normalizing spend to USD at this layer, all downstream marts and
--   Metabase dashboards can safely SUM/AVG without currency confusion.
--
-- EDGE CASES HANDLED:
-- - Google spend in micros and Meta spend in cents are already converted
--   in staging. LinkedIn reports in decimal dollars natively.
-- - Anomaly detection: rows where spend > 0 but impressions = 0 indicate
--   API glitches or billing artifacts. Flagged as is_anomaly so dashboards
--   can exclude them from efficiency metrics (CTR, CPC) without losing
--   visibility into total spend.
-- - EUR campaigns use a hardcoded conversion rate for demo purposes.
--   In production, this would reference a dim_exchange_rates table.
-- ============================================================================

WITH google_performance AS (
    SELECT
        'google_ads' AS channel,
        source_campaign_id,
        metric_date,
        daily_impressions,
        daily_clicks,
        daily_spend_original_currency AS daily_spend_local,
        currency_code
    FROM "dev"."main_staging"."stg_google_ads__performance_daily"
),

meta_performance AS (
    SELECT
        'meta_ads' AS channel,
        source_campaign_id,
        metric_date,
        daily_impressions,
        daily_clicks,
        daily_spend_original_currency AS daily_spend_local,
        currency_code
    FROM "dev"."main_staging"."stg_meta_ads__performance_daily"
),

linkedin_performance AS (
    SELECT
        'linkedin_ads' AS channel,
        source_campaign_id,
        metric_date,
        daily_impressions,
        daily_clicks,
        daily_spend_usd AS daily_spend_local,
        currency_code
    FROM "dev"."main_staging"."stg_linkedin_ads__performance_daily"
),

-- Stack all channels
unioned AS (
    SELECT * FROM google_performance
    UNION ALL
    SELECT * FROM meta_performance
    UNION ALL
    SELECT * FROM linkedin_performance
),

-- Normalize currency and detect anomalies
final AS (
    SELECT
        -- Cross-channel surrogate key (matches int_unified_campaigns)
        md5(cast(coalesce(cast(channel as TEXT), '_dbt_utils_surrogate_key_null_') || '-' || coalesce(cast(source_campaign_id as TEXT), '_dbt_utils_surrogate_key_null_') as TEXT)) AS campaign_key,

        channel,
        source_campaign_id,
        metric_date,

        -- Core metrics
        daily_impressions,
        daily_clicks,

        -- Currency normalization
        -- In production: JOIN to dim_exchange_rates ON (currency_code, metric_date)
        -- For demo: EUR → USD at 1.08 fixed rate
        CAST(ROUND(
            CASE
                WHEN currency_code = 'EUR' THEN CAST(daily_spend_local AS DOUBLE) * 1.08
                ELSE CAST(daily_spend_local AS DOUBLE)
            END
        , 6) AS DOUBLE) AS daily_spend_usd,

        CAST(daily_spend_local AS DOUBLE) AS daily_spend_local,
        currency_code,

        -- Pre-calculated efficiency metrics (NULL-safe via safe_divide macro)
        
    CASE
        WHEN CAST(daily_impressions AS DOUBLE) = 0 OR CAST(daily_impressions AS DOUBLE) IS NULL
        THEN NULL
        ELSE CAST(CAST(daily_clicks AS DOUBLE) AS DOUBLE) / NULLIF(CAST(CAST(daily_impressions AS DOUBLE) AS DOUBLE), 0.0)
    END
 AS daily_ctr,
        
    CASE
        WHEN CAST(daily_clicks AS DOUBLE) = 0 OR CAST(daily_clicks AS DOUBLE) IS NULL
        THEN NULL
        ELSE CAST(CAST(ROUND(CASE WHEN currency_code = 'EUR' THEN CAST(daily_spend_local AS DOUBLE) * 1.08 ELSE CAST(daily_spend_local AS DOUBLE) END, 6) AS DOUBLE) AS DOUBLE) / NULLIF(CAST(CAST(daily_clicks AS DOUBLE) AS DOUBLE), 0.0)
    END
 AS daily_cpc_usd,

        -- Anomaly flag: spend recorded but no impressions served
        -- This catches API sync issues and billing artifacts that would
        -- otherwise distort CTR/CPC calculations in Metabase
        CASE
            WHEN daily_spend_local > 0 AND daily_impressions = 0 THEN TRUE
            ELSE FALSE
        END AS is_anomaly

    FROM unioned
)

SELECT * FROM final
    );
  
  
