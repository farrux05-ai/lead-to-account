  create view "dev"."main_staging"."stg_google_ads__performance_daily__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_google_ads__performance_daily
-- ============================================================================
-- GRAIN: One row per campaign, per day.
-- PURPOSE: Clean and standardize daily performance metrics from Google Ads.
--
-- NOTES:
-- - Google Ads API returns cost in micros (millionths of local currency).
--   We immediately pass this through the global `micros_to_dollars` macro
--   so all downstream models utilize standard decimal representation.
-- - Metrics (impressions, clicks) are coalesced to 0. A NULL impression
--   creates fragile analytical logic in Metabase (e.g. SUMs might fail).
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_google_ads"."google_ads_performance_daily"
),

renamed_and_typed AS (
    SELECT
        -- Dimensional keys
        CAST(campaign_id AS VARCHAR) AS source_campaign_id,
        CAST(date AS DATE) AS metric_date,

        -- Quantitative metrics (defensively coalesced)
        COALESCE(CAST(impressions AS INTEGER), 0) AS daily_impressions,
        COALESCE(CAST(clicks AS INTEGER), 0) AS daily_clicks,

        -- Financial metrics
        -- Utilizing macro to handle micros -> currency translation
        
    ROUND(CAST(cost_micros AS DOUBLE) / 1000000.0, 6)
 AS daily_spend_original_currency,
        CAST(currency_code AS VARCHAR) AS currency_code,

        -- System
        CAST(_loaded_at AS TIMESTAMP) AS _loaded_at

    FROM source
),

deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY source_campaign_id, metric_date 
        ORDER BY _loaded_at DESC
    ) = 1
)

SELECT * FROM deduplicated
  );

[0m15:14:13.836555 [debug] [Thread-2 (]: On model.marketing_warehouse.stg_ga4__sessions_daily: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "marketing_db", "target_name": "dev", "node_id": "model.marketing_warehouse.stg_ga4__sessions_daily"} */

  
  create view "dev"."main_staging"."stg_ga4__sessions_daily__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_ga4__sessions_daily
-- ============================================================================
-- GRAIN: One row per date + combination of UTM source, medium, and campaign.
-- PURPOSE: Extract web analytics sessions and engagement. This forms the 
--          web-behaviour layer that correlates to top-of-funnel ad spend.
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_ga4"."ga4_sessions_daily"
),

renamed_and_typed AS (
    SELECT
        -- Dimensional keys
        CAST(date AS DATE) AS metric_date,
        
        -- UTM Parameters
        -- We nullify "(not set)" to ensure cleaner downstream COALESCE operations
        NULLIF(CAST(source AS VARCHAR), '(not set)') AS utm_source,
        NULLIF(CAST(medium AS VARCHAR), '(not set)') AS utm_medium,
        NULLIF(CAST(campaign AS VARCHAR), '(not set)') AS utm_campaign,

        -- Metrics
        COALESCE(CAST(sessions AS INTEGER), 0) AS daily_sessions,
        COALESCE(CAST(engaged_sessions AS INTEGER), 0) AS daily_engaged_sessions,
        COALESCE(CAST(bounces AS INTEGER), 0) AS daily_bounces,

        -- System
        CAST(_loaded_at AS TIMESTAMP) AS _loaded_at

    FROM source
),

deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY metric_date, utm_source, utm_medium, utm_campaign 
        ORDER BY _loaded_at DESC
    ) = 1
)

SELECT * FROM deduplicated
  );

[0m15:14:13.839573 [debug] [Thread-4 (]: On model.marketing_warehouse.stg_hubspot__contacts: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "marketing_db", "target_name": "dev", "node_id": "model.marketing_warehouse.stg_hubspot__contacts"} */

  
  create view "dev"."main_staging"."stg_hubspot__contacts__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_hubspot__contacts
-- ============================================================================
-- GRAIN: One row per unique HubSpot contact ID.
-- PURPOSE: Extract core CRM contact attributes. Essential for mapping 
--          leads to campaigns and channels.
--
-- NOTES:
-- - `merged_into_contact_id`: HubSpot merges duplicate contacts natively. 
--   We preserve this field to allow downstream models (intermediate) to 
--   redirect historical event records of standard deleted duplicates 
--   towards the surviving parent contact ID.
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_hubspot"."hubspot_contacts"
),

renamed_and_typed AS (
    SELECT
        -- Primary Keys/Identifiers
        CAST(contact_id AS VARCHAR) AS source_contact_id,
        CAST(email AS VARCHAR) AS email,
        
        -- Merge Logic ID mappings
        CAST(merged_into_contact_id AS VARCHAR) AS merged_into_contact_id,

        -- Profile Dimensions
        CAST(first_name AS VARCHAR) AS first_name,
        CAST(last_name AS VARCHAR) AS last_name,
        
        -- State/Funnel Stage
        CAST(lifecycle_stage AS VARCHAR) AS lifecycle_stage,
        CAST(original_source AS VARCHAR) AS original_source,

        -- System
        CAST(created_at AS TIMESTAMP) AS created_at
        
        -- We won't bring _loaded_at for this mock, rely on created_at for grain

    FROM source
),

deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY source_contact_id 
        ORDER BY created_at DESC
    ) = 1
)

SELECT * FROM deduplicated
  );

[0m15:14:13.841881 [debug] [Thread-3 (]: On model.marketing_warehouse.stg_google_ads__campaigns: /* {"app": "dbt", "dbt_version": "1.11.7", "profile_name": "marketing_db", "target_name": "dev", "node_id": "model.marketing_warehouse.stg_google_ads__campaigns"} */

  
  create view "dev"."main_staging"."stg_google_ads__campaigns__dbt_tmp" as (
    -- ============================================================================
-- MODEL: stg_google_ads__campaigns
-- ============================================================================
-- GRAIN: One row per unique Google Ads campaign.
-- PURPOSE: Extract campaign attributes, standardize naming, and ensure a
--          clean, deduplicated spine of campaigns from Google Ads.
-- 
-- NOTES:
-- - In a production environment with Fivetran/Airbyte, API extraction errors
--   often cause duplicate rows during backfills. We use ROW_NUMBER() over
--   _loaded_at to fetch the most recent state of the campaign.
-- - 'campaign_type' and 'status' are explicit dimensions used for filtering.
-- ============================================================================

WITH source AS (
    SELECT * FROM "dev"."main_raw_google_ads"."google_ads_campaigns"
),

renamed_and_typed AS (
    SELECT
        -- Primary Key
        CAST(campaign_id AS VARCHAR) AS source_campaign_id,

        -- Attributes
        CAST(campaign_name AS VARCHAR) AS campaign_name,
        CAST(campaign_type AS VARCHAR) AS campaign_type,
        CAST(status AS VARCHAR) AS campaign_status,
        CAST(currency_code AS VARCHAR) AS currency_code,

        -- System / Metadata
        CAST(_loaded_at AS TIMESTAMP) AS _loaded_at

    FROM source
),

-- Defensive design: deduplicate raw rows keeping the latest extraction
deduplicated AS (
    SELECT 
        *
    FROM renamed_and_typed
    QUALIFY ROW_NUMBER() OVER(
        PARTITION BY source_campaign_id 
        ORDER BY _loaded_at DESC
    ) = 1
)

SELECT * FROM deduplicated
  );

